*.vue linguist-language=JavaScript

# Normalize text files to LF regardless of the platform/local core.autocrlf,
# so ESLint's linebreak-style rule doesn't fail on Windows checkouts.
* text=auto eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.node binary
